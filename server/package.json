{
  "name": "monolith-server",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply monolith-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply monolith-db --remote",
    "db:seed:local": "wrangler d1 execute monolith-db --local --file=src/migrations/0002_seed.sql",
    "db:seed:test-posts:local": "wrangler d1 execute monolith-db --local --file=src/seeds/seed_test_posts.sql",
    "check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
